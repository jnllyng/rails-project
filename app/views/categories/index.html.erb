<div class="page-header">
  <p>Browse By</p>
  <h1>Categories</h1>
</div>

<div class="row row-cols-1 row-cols-md-3 g-4">
  <% @categories.each do |category| %>
    <div class="col">
      <div class="card h-100">
        <div class="card-body text-center py-5">
          <h2 class="card-title mb-3"><%= category.name %></h2>
          <p class="card-text text-muted" style="font-size: 0.9rem;"><%= category.description %></p>
          <p class="mt-3">
            <span class="badge bg-secondary"><%= category.products.count %> products</span>
          </p>
        </div>
        <div class="card-footer">
          <%= link_to "Shop Now", category_path(category), class: "btn btn-dark w-100" %>
        </div>
      </div>
    </div>
  <% end %>
</div>